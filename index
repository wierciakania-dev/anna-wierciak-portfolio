border-top:1px solid var(--line);

margin:65px 0;

}

nav{

display:flex;

gap:22px;

flex-wrap:wrap;

margin-top:2rem;

}

nav a{

color:var(--muted);

text-decoration:none;

}

nav a:hover{

color:#000;

}

a{

color:#000;

}

blockquote{

font-family:Georgia,serif;

font-size:1.35rem;

color:var(--muted);

margin:2.5rem 0;

padding-left:24px;

border-left:2px solid var(--line);

}

.project{

margin-bottom:55px;

}

footer{

margin-top:100px;

padding-top:40px;

border-top:1px solid var(--line);

color:var(--muted);

font-size:.95rem;

}

@media(max-width:700px){

body{

font-size:17px;

}

main{

